# =========================================================================
# PO Tools Connection Credentials Config Template
# Copy this file to '.env' and fill in your actual credentials.
# The '.env' file is ignored by Git to keep your credentials secure.
# =========================================================================

# --- JIRA CONFIGURATION ---
# Your Jira Server Base URL (e.g. Jira Cloud or Jira Server)
JIRA_SERVER=https://your-company.atlassian.net

# Your secure Jira Personal Access Token (PAT)
JIRA_API_TOKEN=your_jira_pat_here


# --- CONFLUENCE CONFIGURATION ---
# Your Confluence Server Base URL (e.g., https://your-company.atlassian.net/wiki or Server URL)
CONFLUENCE_SERVER=https://your-company.atlassian.net/confluence

# Your secure Confluence Personal Access Token (PAT)
CONFLUENCE_API_TOKEN=your_confluence_pat_here

# Default Confluence Space Key (e.g., DS)
CONFLUENCE_SPACE=DS

# Default Confluence Page Title (e.g., Release Notes)
CONFLUENCE_PAGE=Release Notes


# --- PROJECT & BRANDING CONFIGURATION ---
# Project / Company Name
PROJECT_NAME=PO Tools Enterprise

# Primary Color Theme Hex (e.g., #3B82F6)
PRIMARY_COLOR=#3B82F6

# Default Overview Sprint Number / Name (for Step 1 Overview query)
OVERVIEW_SPRINT_NUM=1

# Default Outlook Sprint Number / Name (for Step 1 Outlook query)
OUTLOOK_SPRINT_NUM=2

# Default Cover Page Sprint name (e.g., Sprint 14)
COVER_SPRINT_NAME=Sprint 14

# Default logo image file path (leave blank to use streamlit uploader)
LOGO_IMAGE_PATH=

# Default cover page image file path (leave blank to use streamlit uploader)
COVER_IMAGE_PATH=

# Default Welcome Message Content (displays on the PDF cover page)
SPRINT_WELCOME_MESSAGE=Welcome to the Sprint Review session. This document consolidates our delivered sprint capabilities, scheduled target releases, and interactive product demo presentations. We thank our engineering team and product stakeholders for their collaborative efforts.

# Default Introduction Content (Support raw markdown text with \n for newlines)
RELEASE_NOTES_INTRO=### Dear Users & Partners,\n\nWe are excited to share the **Release Notes** for our latest development cycle. In this iteration, our engineering team focused on bolstering platform security, optimizing database transaction queries, and releasing crucial merchant billing integrations.\n\n**Delivered Highlights:**\n* **Enhanced Security:** Implemented Google & GitHub OAuth2 Single Sign-On (SSO).\n* **Payment Processing:** Integrated recurrent merchant subscription flows via Stripe.\n* **Document Services:** Finalized robust PDF invoicing exporters inside staging.\n\nThank you for your continuous feedback, which drives our iterative development process.\n\n*Best Regards,*\n**The Product Management Team**

# --- EXPORT FILE NAMES CONFIGURATION ---
# Default export filename base for Sprint Review PDF
DEFAULT_FILENAME_SPRINT_REVIEW=Sprint_Review_Report

# Default export filename base for Release Notes PDF
DEFAULT_FILENAME_RELEASE_NOTES=Release_Notes
